            <TouchableOpacity
              style={[styles.volumeDown, { backgroundColor: done('volume') ? '#10B981' : b.buttonColor },
                highlightedPart === 'volume' && styles.highlighted]}
              onPress={() => handlePartPress(parts[1])}
              accessibilityLabel="Volume Down"
            />
          </View>
          {/* Speaker slot */}
          <TouchableOpacity
            style={[styles.speaker, { backgroundColor: done('speaker') ? '#10B981' : b.buttonColor },
              highlightedPart === 'speaker' && styles.highlighted]}
