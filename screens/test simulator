// ─── Power On/Off Simulator ───────────────────────────────────────────────────
const PowerSimulator = ({ onSuccess, brand }) => {
  const [phoneState, setPhoneState] = useState("off");
  const [pressTime, setPressTime] = useState(0);
  const pressInterval = useRef(null);
  const b = brand || PHONE_BRANDS[0];

  const handlePowerPress = () => {
    if (phoneState === "off") {
      pressInterval.current = setInterval(() => setPressTime(prev => prev + 100), 100);
    }
  };

  const handlePowerRelease = () => {
    if (pressInterval.current) clearInterval(pressInterval.current);
    if (pressTime >= 1000 && phoneState === "off") {
      Vibration.vibrate(20);
      setPhoneState("booting");
      setTimeout(() => {
        setPhoneState("on");
        onSuccess();
        TTSWrapper.speak("Phone turned on!");
      }, 1200);
    } else if (phoneState === "on") {
      Vibration.vibrate(10);
      setPhoneState("off");
      TTSWrapper.speak("Phone turned off!");
    }
    setPressTime(0);
  };

  return (
    <View style={styles.simulatorContainer}>
      <Text style={styles.simulatorTitle}>
        {phoneState === "off" ? "Hold power button for 1 second" : "Tap power to turn off"}
      </Text>
      <View style={[styles.phoneFrame, { backgroundColor: b.frameColor }]}>
        <View style={[styles.phoneBody, { backgroundColor: b.color, borderRadius: b.screenRadius + 4 }]}>
          <TouchableOpacity
            style={[styles.powerButton, { backgroundColor: pressTime > 0 ? b.accentColor : b.buttonColor },
              phoneState === 'on' && { backgroundColor: '#10B981' }]}
            onPressIn={handlePowerPress}
            onPressOut={handlePowerRelease}
            accessibilityLabel="Power Button"
          />
          <View style={[styles.phoneScreen, { borderRadius: b.screenRadius, backgroundColor: b.wallpaper }]}>
            {phoneState === "off" && <View style={{ flex: 1, backgroundColor: '#000' }} />}
            {phoneState === "booting" && (
              <View style={styles.bootScreen}>
                <Text style={[styles.brandBootLogo, { color: b.accentColor }]}>{b.logo}</Text>
                <Text style={[styles.bootText, { color: b.accentColor }]}>{b.name}</Text>
              </View>
            )}
            {phoneState === "on" && (
              <View style={[styles.homeScreen, { backgroundColor: b.wallpaper }]}>
                <BrandStatusBar brand={b} />
                <Text style={[styles.welcomeText, { color: b.accentColor }]}>Welcome!</Text>
              </View>
            )}
          </View>
        </View>
      </View>
      {pressTime > 0 && phoneState === "off" && (
        <View style={styles.pressIndicator}>
          <View style={[styles.pressBar, { width: `${Math.min(pressTime / 10, 100)}%`, backgroundColor: b.accentColor }]} />
          <Text style={styles.pressText}>Hold to power on...</Text>
        </View>
      )}
    </View>
  );
};

// ─── Unlock Simulator ─────────────────────────────────────────────────────────
const UnlockSimulator = ({ onSuccess, brand }) => {
  const [isLocked, setIsLocked] = useState(true);
  const slideAnim = useRef(new Animated.Value(0)).current;
  const swipeX = useRef(new Animated.Value(0)).current;
  const b = brand || PHONE_BRANDS[0];

  const panResponder = useRef(PanResponder.create({
    onStartShouldSetPanResponder: () => isLocked,
    onMoveShouldSetPanResponder: (_, gs) => isLocked && Math.abs(gs.dx) > 10,
    onPanResponderMove: Animated.event([null, { dx: swipeX }], { useNativeDriver: false }),
    onPanResponderRelease: (_, gs) => {
      if (gs.dx > 60) {
        Vibration.vibrate(15);
        setIsLocked(false);
        TTSWrapper.speak("Phone unlocked!");
        onSuccess();
        Animated.timing(slideAnim, { toValue: 1, duration: 300, useNativeDriver: true }).start();
      } else {
        Animated.spring(swipeX, { toValue: 0, useNativeDriver: false }).start();
      }
    },
  })).current;

  // iPhone uses PIN entry style instead of swipe
  const [pin, setPin] = useState('');
  const isIphone = b.id === 'iphone';

  const handlePinPress = (digit) => {
    if (pin.length < 6) {
      const newPin = pin + digit;
      setPin(newPin);
      Vibration.vibrate(8);
      if (newPin.length === 6) {
        setTimeout(() => {
          setIsLocked(false);
          TTSWrapper.speak("Phone unlocked!");
          onSuccess();
        }, 300);
      }
    }
  };

  return (
    <View style={styles.simulatorContainer}>
      <Text style={styles.simulatorTitle}>
        {isLocked
          ? (isIphone ? "Enter any 6-digit PIN" : "Swipe right to unlock")
          : "Phone unlocked!"}
      </Text>
      <View style={[styles.phoneFrame, { backgroundColor: b.frameColor }]}>
        <View style={[styles.phoneBody, { backgroundColor: b.color, borderRadius: b.screenRadius + 4 }]}>
          <View style={[styles.phoneScreen, { borderRadius: b.screenRadius, backgroundColor: b.wallpaper }]}>
            {isLocked ? (
              <View style={[styles.lockScreen, { backgroundColor: b.wallpaper }]}>
                <BrandStatusBar brand={b} />
                <View style={styles.clockDisplay}>
                  <Text style={styles.clockTime}>9:41</Text>
                  <Text style={styles.clockDate}>Tuesday, September 10</Text>
                </View>
                {isIphone ? (
                  <View style={styles.pinPad}>
                    <View style={styles.pinDots}>
                      {[0,1,2,3,4,5].map(i => (
                        <View key={i} style={[styles.pinDot,
                          i < pin.length && { backgroundColor: b.accentColor }]} />
                      ))}
                    </View>
                    <View style={styles.pinGrid}>
                      {['1','2','3','4','5','6','7','8','9','','0','⌫'].map((d, i) => (
                        <TouchableOpacity
                          key={i}
                          style={[styles.pinButton, !d && { opacity: 0 }]}
                          onPress={() => {
                            if (d === '⌫') setPin(p => p.slice(0,-1));
                            else if (d) handlePinPress(d);
                          }}
                          disabled={!d}
                        >
                          <Text style={styles.pinButtonText}>{d}</Text>
                        </TouchableOpacity>
                      ))}
                    </View>
                  </View>
                ) : (
                  <View style={styles.swipeArea} {...panResponder.panHandlers}>
                    <Animated.View style={[styles.swipeIndicator, { transform: [{ translateX: swipeX }] }]}>
                      <Icon name="chevron-right" size={16} color={b.accentColor} />
                      <Text style={[styles.swipeText, { color: b.accentColor }]}>Swipe to unlock</Text>
                    </Animated.View>
                  </View>
                )}
              </View>
            ) : (
              <Animated.View style={[styles.homeScreen, { backgroundColor: b.wallpaper }]}>
                <BrandStatusBar brand={b} />
                <View style={styles.appGrid}>
                  {["phone", "comment", "camera", "cog"].map((icon, idx) => (
                    <View key={idx} style={styles.appIcon}>
                      <View style={[styles.appIconBg, { backgroundColor: b.accentColor }]}>
                        <Icon name={icon} size={20} color="#fff" />
                      </View>
                    </View>
                  ))}
                </View>
              </Animated.View>
            )}
          </View>
        </View>
      </View>
    </View>
  );
};

// ─── Touch Gesture Simulator ──────────────────────────────────────────────────
const TouchSimulator = ({ onSuccess, brand }) => {
  const [gestures, setGestures] = useState({ tap: false, swipe: false, pinch: false });
  const [currentGesture, setCurrentGesture] = useState(null);
  const b = brand || PHONE_BRANDS[0];
  const swipeX = useRef(new Animated.Value(0)).current;

  const panResponder = useRef(PanResponder.create({
    onStartShouldSetPanResponder: () => !gestures.swipe,
    onMoveShouldSetPanResponder: (_, gs) => !gestures.swipe && Math.abs(gs.dx) > 10,
    onPanResponderMove: Animated.event([null, { dx: swipeX }], { useNativeDriver: false }),
    onPanResponderRelease: (_, gs) => {
      if (gs.dx > 80 && !gestures.swipe) {
        setCurrentGesture("swipe");
        const next = { ...gestures, swipe: true };
        setGestures(next);
        TTSWrapper.speak("Nice swipe!");
        setTimeout(() => setCurrentGesture(null), 500);
        swipeX.setValue(0);
        if (next.tap && next.pinch) onSuccess();
      } else {
        Animated.spring(swipeX, { toValue: 0, useNativeDriver: false }).start();
      }
    },
  })).current;

  const handlePinch = () => {
    if (!gestures.pinch) {
      Vibration.vibrate(10);
      setCurrentGesture("pinch");
      const next = { ...gestures, pinch: true };
      setGestures(next);
      TTSWrapper.speak("Good pinch!");
      setTimeout(() => setCurrentGesture(null), 500);
      if (next.tap && next.swipe) onSuccess();
    }
  };

  const handleTap = () => {
    if (!gestures.tap) {
      Vibration.vibrate(8);
      setCurrentGesture("tap");
      const next = { ...gestures, tap: true };
      setGestures(next);
      TTSWrapper.speak("Great tap!");
      setTimeout(() => setCurrentGesture(null), 500);
      if (next.swipe && next.pinch) onSuccess();
    }
  };

  return (
    <View style={styles.simulatorContainer}>
      <Text style={styles.simulatorTitle}>Try all three gestures</Text>
      <PhoneShell brand={b}>
        <View style={styles.gestureArea}>
          <TouchableOpacity
            style={[styles.gestureButton,
              { borderColor: b.accentColor },
              currentGesture === "tap" && { backgroundColor: b.accentColor },
              gestures.tap && styles.gestureCompleted]}
            onPress={handleTap} activeOpacity={0.7} accessibilityLabel="Tap">
            <Icon name="hand-point-up" size={26} color={gestures.tap ? '#fff' : b.accentColor} />
            <Text style={[styles.gestureLabel, { color: gestures.tap ? '#fff' : b.accentColor }]}>Tap</Text>
          </TouchableOpacity>
          <Animated.View
            style={[styles.gestureButton, { marginTop: 12, marginBottom: 12, borderColor: b.accentColor,
              transform: [{ translateX: swipeX }] },
              currentGesture === "swipe" && { backgroundColor: b.accentColor },
              gestures.swipe && styles.gestureCompleted]}
            {...panResponder.panHandlers} accessibilityLabel="Swipe">
            <Icon name="hand-paper" size={26} color={gestures.swipe ? '#fff' : b.accentColor} />
            <Text style={[styles.gestureLabel, { color: gestures.swipe ? '#fff' : b.accentColor }]}>Swipe →</Text>
          </Animated.View>
          <TouchableOpacity
            style={[styles.gestureButton, { borderColor: b.accentColor },
              currentGesture === "pinch" && { backgroundColor: b.accentColor },
              gestures.pinch && styles.gestureCompleted]}
            onLongPress={handlePinch} delayLongPress={200} activeOpacity={0.7} accessibilityLabel="Pinch">
            <Icon name="compress-arrows-alt" size={26} color={gestures.pinch ? '#fff' : b.accentColor} />
            <Text style={[styles.gestureLabel, { color: gestures.pinch ? '#fff' : b.accentColor }]}>Pinch</Text>
            <Text style={{ color: '#94A3B8', fontSize: 9, marginTop: 2 }}>Long press</Text>
          </TouchableOpacity>
        </View>
      </PhoneShell>
      <View style={styles.progressIndicator}>
        <Text style={styles.simProgressText}>
          {Object.values(gestures).filter(Boolean).length}/3 gestures completed
        </Text>
      </View>
    </View>
  );
};

