  const b = brand || PHONE_BRANDS[0];
  const done = (id) => identifiedParts.has(id);

  return (
    <View style={styles.simulatorContainer}>
      <Text style={styles.simulatorTitle}>Tap each part to learn about it</Text>
      <View style={[styles.phoneFrame, { backgroundColor: b.frameColor }]}>
