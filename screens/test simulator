const VolumeSimulator = ({ onSuccess, brand }) => {
  const [volume, setVolume] = useState(50);
  const [brightness, setBrightness] = useState(50);
  const [showVolumeControl, setShowVolumeControl] = useState(false);
  const b = brand || PHONE_BRANDS[0];

  const checkSuccess = (v, br) => { if (v >= 80 && br >= 80) onSuccess(); };

  const handleVolumeButtonPress = (dir) => {
    setShowVolumeControl(true);
    Vibration.vibrate(8);
    const nv = dir === "up" ? Math.min(100, volume + 10) : Math.max(0, volume - 10);
    setVolume(nv);
    setTimeout(() => setShowVolumeControl(false), 1200);
    checkSuccess(nv, brightness);
  };

  return (
    <View style={styles.simulatorContainer}>
      <Text style={styles.simulatorTitle}>Adjust volume and brightness to 80%</Text>
      <View style={[styles.phoneFrame, { backgroundColor: b.frameColor }]}>
        <View style={[styles.phoneBody, { backgroundColor: b.color, borderRadius: b.screenRadius + 4 }]}>
          <View style={styles.volumeButtons}>
            <TouchableOpacity style={[styles.volumeUp, { backgroundColor: b.buttonColor }]}
              onPress={() => handleVolumeButtonPress("up")} accessibilityLabel="Volume Up" />
            <TouchableOpacity style={[styles.volumeDown, { backgroundColor: b.buttonColor }]}
              onPress={() => handleVolumeButtonPress("down")} accessibilityLabel="Volume Down" />
          </View>
          <View style={[styles.phoneScreen, { borderRadius: b.screenRadius, backgroundColor: b.wallpaper,
            opacity: Math.min(1, Math.max(brightness / 100, 0.3) + 0.3) }]}>
            {showVolumeControl && (
              <View style={styles.volumeOverlay}>
                <Icon name="volume-up" size={16} color={b.accentColor} />
                <View style={styles.volumeBar}>
                  <View style={[styles.volumeFill, { width: `${volume}%`, backgroundColor: b.accentColor }]} />
                </View>
                <Text style={styles.volumeText}>{volume}%</Text>
              </View>
            )}
            <View style={[styles.settingsScreen, { backgroundColor: b.wallpaper }]}>
              <BrandStatusBar brand={b} />
              <Text style={[styles.settingsTitle, { color: b.accentColor }]}>Settings</Text>
              <View style={styles.settingItem}>
                <View style={styles.settingRow}>
                  <Icon name="volume-up" size={14} color={b.accentColor} />
                  <Text style={styles.settingLabel}>Volume</Text>
                  <Text style={styles.settingValue}>{volume}%</Text>
                </View>
                <Slider style={styles.settingSlider} value={volume}
                  onValueChange={v => { setVolume(v); checkSuccess(v, brightness); }}
                  minimumValue={0} maximumValue={100} step={10}
                  minimumTrackTintColor={b.accentColor} maximumTrackTintColor="#CBD5E1" />
              </View>
              <View style={styles.settingItem}>
                <View style={styles.settingRow}>
                  <Icon name="sun" size={14} color={b.accentColor} />
                  <Text style={styles.settingLabel}>Brightness</Text>
                  <Text style={styles.settingValue}>{brightness}%</Text>
                </View>
                <Slider style={styles.settingSlider} value={brightness}
                  onValueChange={v => { setBrightness(v); checkSuccess(volume, v); }}
                  minimumValue={0} maximumValue={100} step={10}
                  minimumTrackTintColor={b.accentColor} maximumTrackTintColor="#CBD5E1" />
              </View>
            </View>
          </View>
        </View>
      </View>
    </View>
  );
};

// ─── Call Simulator ───────────────────────────────────────────────────────────
const CallSimulator = ({ onSuccess, brand }) => {
  const [callState, setCallState] = useState("incoming");
  const [callDuration, setCallDuration] = useState(0);
  const durationInterval = useRef(null);
  const b = brand || PHONE_BRANDS[0];

  useEffect(() => {
    if (callState === "answered") {
      durationInterval.current = setInterval(() => setCallDuration(p => p + 1), 1000);
    } else {
      if (durationInterval.current) clearInterval(durationInterval.current);
    }
    return () => { if (durationInterval.current) clearInterval(durationInterval.current); };
  }, [callState]);

  const fmt = (s) => `${Math.floor(s/60)}:${(s%60).toString().padStart(2,'0')}`;

  return (
    <View style={styles.simulatorContainer}>
      <Text style={styles.simulatorTitle}>
        {callState === "incoming" ? "Answer or decline the call"
          : callState === "answered" ? "You are in a call" : "Call ended"}
      </Text>
      <PhoneShell brand={b}>
        {callState === "incoming" && (
          <View style={[styles.incomingCall, { backgroundColor: b.wallpaper }]}>
            <BrandStatusBar brand={b} />
            <View style={styles.callerInfo}>
              <View style={[styles.callerAvatar, { backgroundColor: b.accentColor + '33' }]}>
                <Icon name="user" size={32} color={b.accentColor} />
              </View>
              <Text style={styles.callerName}>Mom</Text>
              <Text style={styles.callerNumber}>+63 912 345 6789</Text>
              <Text style={[styles.callStatus, { color: b.accentColor }]}>Incoming call...</Text>
            </View>
            <View style={styles.callControls}>
              <TouchableOpacity style={[styles.callButton, styles.declineButton]}
                onPress={() => { Vibration.vibrate(15); setCallState("ended"); TTSWrapper.speak("Call declined!"); onSuccess(); }}
                accessibilityLabel="Decline">
                <Icon name="phone-slash" size={20} color="#fff" />
              </TouchableOpacity>
              <TouchableOpacity style={[styles.callButton, styles.answerButton]}
                onPress={() => { Vibration.vibrate(15); setCallState("answered"); TTSWrapper.speak("Call answered!"); onSuccess(); }}
                accessibilityLabel="Answer">
                <Icon name="phone" size={20} color="#fff" />
              </TouchableOpacity>
            </View>
          </View>
        )}
        {callState === "answered" && (
          <View style={[styles.activeCall, { backgroundColor: b.wallpaper }]}>
            <BrandStatusBar brand={b} />
            <View style={styles.callerInfo}>
              <View style={[styles.callerAvatar, { backgroundColor: b.accentColor + '33' }]}>
                <Icon name="user" size={32} color={b.accentColor} />
              </View>
              <Text style={styles.callerName}>Mom</Text>
              <Text style={[styles.callDuration, { color: b.accentColor }]}>{fmt(callDuration)}</Text>
            </View>
            <View style={styles.callControls}>
              <TouchableOpacity style={[styles.callButton, styles.endButton]}
                onPress={() => { Vibration.vibrate(10); setCallState("ended"); TTSWrapper.speak("Call ended!"); }}
                accessibilityLabel="End Call">
                <Icon name="phone-slash" size={20} color="#fff" />
              </TouchableOpacity>
            </View>
          </View>
        )}
        {callState === "ended" && (
          <View style={[styles.callEnded, { backgroundColor: b.wallpaper }]}>
            <Icon name="phone" size={48} color="#64748B" />
            <Text style={styles.callEndedText}>Call ended</Text>
          </View>
        )}
      </PhoneShell>
    </View>
  );
};

// ─── Message Simulator ────────────────────────────────────────────────────────
const MessageSimulator = ({ onSuccess, brand }) => {
  const [message, setMessage] = useState("");
  const [messages, setMessages] = useState([
    { id: 1, text: "Hi! How are you?", sender: "contact", time: "9:30 AM" },
  ]);
  const b = brand || PHONE_BRANDS[0];

  const handleSend = () => {
    if (message.trim().toLowerCase() === "hello") {
      Vibration.vibrate(10);
      setMessages(prev => [...prev, { id: Date.now(), text: message, sender: "user", time: "9:41 AM" }]);
      setMessage("");
      TTSWrapper.speak("Message sent!");
      setTimeout(() => onSuccess(), 500);
    }
  };

  return (
    <View style={styles.simulatorContainer}>
      <Text style={styles.simulatorTitle}>Type "hello" and send it</Text>
      <PhoneShell brand={b}>
        <View style={[styles.messageApp, { backgroundColor: b.wallpaper }]}>
          <View style={[styles.messageHeader, { backgroundColor: b.accentColor + '22' }]}>
            <BrandStatusBar brand={b} />
            <View style={styles.contactInfo}>
              <View style={[styles.contactAvatar, { backgroundColor: b.accentColor }]}>
                <Icon name="user" size={12} color="#fff" />
              </View>
              <Text style={styles.contactName}>John</Text>
            </View>
          </View>
          <ScrollView style={styles.messagesContainer} showsVerticalScrollIndicator={false}>
            {messages.map(msg => (
              <View key={msg.id} style={[styles.messageBubble,
                msg.sender === "user"
                  ? [styles.userMessage, { backgroundColor: b.accentColor }]
                  : styles.contactMessage]}>
                <Text style={styles.messageText}>{msg.text}</Text>
                <Text style={styles.messageTime}>{msg.time}</Text>
              </View>
            ))}
          </ScrollView>
          <View style={[styles.messageInput, { backgroundColor: b.accentColor + '11' }]}>
            <TextInput
              style={styles.messageTextInput}
              value={message}
              onChangeText={setMessage}
              placeholder="Type hello..."
              placeholderTextColor="#94A3B8"
              autoCapitalize="none"
              autoCorrect={false}
              returnKeyType="send"
              onSubmitEditing={handleSend}
            />
            <TouchableOpacity
              style={[styles.sendButton, message.trim().toLowerCase() === "hello" && { backgroundColor: b.accentColor }]}
              onPress={handleSend}
              disabled={message.trim().toLowerCase() !== "hello"}
              accessibilityLabel="Send">
              <Icon name="paper-plane" size={11} color="#fff" />
            </TouchableOpacity>
          </View>
        </View>
      </PhoneShell>
      <View style={styles.instructionText}>
        <Text style={styles.hintText}>Hint: Type exactly "hello" (lowercase)</Text>
      </View>
    </View>
  );
};

